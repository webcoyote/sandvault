#!/bin/bash
set -Eeuo pipefail
trap 'echo "${BASH_SOURCE[0]}: line $LINENO: $BASH_COMMAND: exitcode $?"' ERR

###############################################################################
# Functions
###############################################################################
info () {
    echo >&2 -e "ℹ️ \033[36m$*\033[0m"
}
error () {
    echo >&2 -e "❌ \033[31m$*\033[0m"
}
abort () {
    error "$*"
    exit 1
}

SANDVAULT_USER=sandvault-$USER
if ! SANDVAULT_UID=$(dscl . -read "/Users/$SANDVAULT_USER" UniqueID 2>/dev/null | awk '{print $2}') ; then
    abort "$SANDVAULT_USER does not exist"
fi

# Stop host-side browser instances (each sandvault session runs its own).
# Sandvault supports both Chrome and Lightpanda backends.
BROWSER_STATE_DIR="$HOME/.local/state/sandvault"
kill_browser() {
    local label="$1"
    local pid="$2"
    [[ -n "$pid" ]] || return 0
    info "Stopping $label (PID $pid)"
    kill "$pid" 2>/dev/null || true
    for (( i=0; i<20; i++ )); do
        kill -0 "$pid" 2>/dev/null || return 0
        sleep 0.1
    done
    if kill -0 "$pid" 2>/dev/null; then
        kill -9 "$pid" 2>/dev/null || true
    fi
}
while IFS= read -r pid; do
    kill_browser Chrome "$pid"
done < <(pgrep -f "user-data-dir=$BROWSER_STATE_DIR/chrome-data-" 2>/dev/null || true)
# Lightpanda processes don't carry a sandvault-specific argv marker, so
# match them via the per-session log path that `sv` redirects them to.
while IFS= read -r pid; do
    kill_browser lightpanda "$pid"
done < <(pgrep -f "lightpanda.*serve" 2>/dev/null || true)
rm -rf "$BROWSER_STATE_DIR"/chrome-data-* "$BROWSER_STATE_DIR"/chrome-*.log "$BROWSER_STATE_DIR"/lightpanda-*.log

if [[ -z "$(ps -u "$SANDVAULT_USER" -o pid=)" ]] ; then
    info "$SANDVAULT_USER has no processes"
    exit 0
fi

info "Booting $SANDVAULT_USER"
sudo launchctl bootout "user/$SANDVAULT_UID" || true
sudo /usr/bin/pkill -9 -u "$SANDVAULT_USER" || true
