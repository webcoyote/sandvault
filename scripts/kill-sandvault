#!/bin/bash
set -Eeuo pipefail
trap 'echo "${BASH_SOURCE[0]}: line $LINENO: $BASH_COMMAND: exitcode $?"' ERR

###############################################################################
# Functions
###############################################################################
info () {
    echo >&2 -e "ℹ️ \033[36m$*\033[0m"
}
error () {
    echo >&2 -e "❌ \033[31m$*\033[0m"
}
abort () {
    error "$*"
    exit 1
}

SANDVAULT_USER=sandvault-$USER
if ! SANDVAULT_UID=$(dscl . -read "/Users/$SANDVAULT_USER" UniqueID 2>/dev/null | awk '{print $2}') ; then
    abort "$SANDVAULT_USER does not exist"
fi

# Stop host-side Chrome instances (each sandvault session runs its own)
CHROME_STATE_DIR="$HOME/.local/state/sandvault"
while IFS= read -r chrome_pid; do
    [[ -n "$chrome_pid" ]] || continue
    info "Stopping Chrome (PID $chrome_pid)"
    kill "$chrome_pid" 2>/dev/null || true
    for (( i=0; i<20; i++ )); do
        kill -0 "$chrome_pid" 2>/dev/null || break
        sleep 0.1
    done
    if kill -0 "$chrome_pid" 2>/dev/null; then
        kill -9 "$chrome_pid" 2>/dev/null || true
    fi
done < <(pgrep -f "user-data-dir=$CHROME_STATE_DIR/chrome-data-" 2>/dev/null || true)
rm -rf "$CHROME_STATE_DIR"/chrome-data-* "$CHROME_STATE_DIR"/chrome-*.log

if [[ -z "$(ps -u "$SANDVAULT_USER" -o pid=)" ]] ; then
    info "$SANDVAULT_USER has no processes"
    exit 0
fi

info "Booting $SANDVAULT_USER"
sudo launchctl bootout "user/$SANDVAULT_UID" || true
sudo /usr/bin/pkill -9 -u "$SANDVAULT_USER" || true
