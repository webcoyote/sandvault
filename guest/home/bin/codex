#!/bin/bash
set -Eeuo pipefail
trap 'echo >&2 "${BASH_SOURCE[0]}: line $LINENO: $BASH_COMMAND: exitcode $?"' ERR

unset CODEX
if [[ "${SV_NATIVE_INSTALL:-}" == "true" ]]; then
    NPM_PREFIX="${HOME}/node_modules"
    NPM_BIN="$NPM_PREFIX/bin"
    if [[ ! -x "$NPM_BIN/codex" ]]; then
        echo >&2 "Installing Codex natively with npm..."
        npm install --prefix "$NPM_PREFIX" -g @openai/codex
    fi
    CODEX="$NPM_BIN/codex"
elif command -v brew &>/dev/null ; then
    HOMEBREW_PREFIX="${HOMEBREW_PREFIX:-"$(brew --prefix)"}"
    if [[ -x "$HOMEBREW_PREFIX/bin/codex" ]]; then
        # Homebrew install
        CODEX="$HOMEBREW_PREFIX/bin/codex"
    fi
fi

if [[ -z "${CODEX:-}" || ! -x "$CODEX" ]]; then
    echo >&2 "ERROR: codex is not installed"
    exit 1
fi

echo >&2 "$USER: running codex --dangerously-bypass-approvals-and-sandbox"
exec "$CODEX" --dangerously-bypass-approvals-and-sandbox "$@"
